{
	"manifest_version": 3,
	"name": "Script Patcher",
	"description": "Patch matched JavaScript files with sandboxed user-defined rules.",
	"version": "1.2.0",
	"minimum_chrome_version": "100",
	"permissions": [
		"debugger",
		"tabs",
		"storage",
		"offscreen"
	],
	"host_permissions": [
		"*://*/*"
	],
	"background": {
		"service_worker": "serviceWorker.js",
		"type": "module"
	},
	"options_page": "options.html",
	"sandbox": {
		"pages": [
			"sandbox.html"
		]
	},
	"icons": {
		"16": "assets/img/ScriptPatcher.logo.png",
		"24": "assets/img/ScriptPatcher.logo.png",
		"32": "assets/img/ScriptPatcher.logo.png",
		"48": "assets/img/ScriptPatcher.logo.png",
		"128": "assets/img/ScriptPatcher.logo.png"
	},
	"action": {
		"default_popup": "options.html",
		"default_icon": {
			"16": "assets/img/ScriptPatcher.logo.png",
			"24": "assets/img/ScriptPatcher.logo.png",
			"32": "assets/img/ScriptPatcher.logo.png",
			"48": "assets/img/ScriptPatcher.logo.png",
			"128": "assets/img/ScriptPatcher.logo.png"
		}
	}
}
