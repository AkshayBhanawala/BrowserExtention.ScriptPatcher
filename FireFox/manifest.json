{
	"manifest_version": 3,
	"name": "Script Patcher",
	"description": "Patch matched JavaScript files with sandboxed user-defined rules.",
	"version": "1.1",
	"permissions": [
		"webRequest",
		"webRequestBlocking",
		"webRequestFilterResponse",
		"tabs",
		"storage"
	],
	"host_permissions": [
		"*://*/*"
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "script-patcher@TH3-AZ.com",
			"strict_min_version": "140.0"
		}
	},
	"background": {
		"scripts": [
			"serviceWorker.js"
		]
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "assets/ScriptPatcher.logo.png",
		"24": "assets/ScriptPatcher.logo.png",
		"32": "assets/ScriptPatcher.logo.png",
		"48": "assets/ScriptPatcher.logo.png",
		"128": "assets/ScriptPatcher.logo.png"
	},
	"action": {
		"default_popup": "options.html",
		"default_icon": {
			"16": "assets/ScriptPatcher.logo.png",
			"24": "assets/ScriptPatcher.logo.png",
			"32": "assets/ScriptPatcher.logo.png",
			"48": "assets/ScriptPatcher.logo.png",
			"128": "assets/ScriptPatcher.logo.png"
		}
	}
}
